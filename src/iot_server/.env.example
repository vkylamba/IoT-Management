# Django core
DJANGO_SECRET_KEY=change-me-to-a-strong-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8113

# Superuser bootstrap (used by startup scripts/management commands if configured)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_EMAIL=admin@example.com

# MongoDB (primary Django DB)
MONGODB_USERNAME=root
MONGODB_PASSWORD=example
MONGODB_HOST=mongo
MONGODB_PORT=27017
MONGODB_NAME=mongotestdb

# ClickHouse (time-series/analytics)
CLICKHOUSE_DATABASE_HOST=database-clickhouse
CLICKHOUSE_DATABASE_PORT=8123
CLICKHOUSE_DATABASE_NAME=iotdatabase
CLICKHOUSE_DATABASE_USERNAME=root
CLICKHOUSE_DATABASE_PASSWORD=root

# Redis (cache + channels)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Application tuning
DEVICE_CACHE_TTL_MINUTES=10
WEATHER_DATA_CACHE_MINUTES=30
DEFAULT_SYNC_FREQUENCY_MINUTES=10

# Optional integrations
OPENWEATHERMAP_API_KEY=
TELEGRAM_BOT_TOKEN=
SUPERSET_ENABLED=False
SENTRY_DSN=

# MQTT client settings
MQTT_BROKER=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60
MQTT_USE_SSL=False
ROOT_CA=
